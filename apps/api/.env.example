# Copy to `.env` (same directory) and fill in secrets.
# Every variable here maps 1:1 to a field on axon.config.Settings.

# --- Core ---
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# --- Database ---
# Host-run API talks to dockerized Postgres on localhost.
# (docker-compose overrides this with the in-network `db` hostname.)
DATABASE_URL=postgresql+psycopg://axon:axon@localhost:5434/axon

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# --- Job queue / worker (defaults shown; uncomment to change) ---
#WORKER_POLL_INTERVAL_S=2.0
#JOB_MAX_ATTEMPTS=3
#JOB_RETRY_BACKOFF_S=15.0
#JOB_STALE_LOCK_SECONDS=300

# --- Claim extraction ---
#EXTRACTION_BATCH_SIZE=10

# --- Drift verification ---
#VERIFY_BUDGET=50
#VERIFY_EVENT_BUDGET=25
#VERIFY_MAX_SOURCE_CHARS=8000

# --- Remediation ---
#REMEDIATION_BUDGET=10
#REMEDIATION_MIN_CONFIDENCE=0.6

# --- Entity linker ---
#LINKER_SIMILARITY_THRESHOLD=0.60
#LINKER_TOP_K=3
#LINKER_MAX_LINKS_PER_CLAIM=3

# --- LLM provider ---
# One of: openai | anthropic (selects the completion provider).
# Embeddings ALWAYS use OpenAI (Anthropic has no embeddings endpoint), so
# OPENAI_API_KEY is required even when LLM_PROVIDER=anthropic.
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Model overrides — uncomment to change
# (defaults: gpt-5-mini / claude-sonnet-5 / text-embedding-3-small)
#OPENAI_MODEL=
# =============================================================================
# Deployment / Production Overrides
# =============================================================================

# Define the environment. If unset, it defaults to 'development' in docker-compose.yml.
# Set to 'production' for actual deployments.
# ENVIRONMENT=production

# Define allowed CORS origins. If unset, it defaults to 'http://localhost:3000'.
# For production, supply a comma-separated list of origins.
# CORS_ORIGINS=http://localhost:3000,https://my-production-domain.com

# For the frontend container, provide the public API URL.
# NEXT_PUBLIC_API_URL=https://api.my-production-domain.com

#ANTHROPIC_MODEL=
#EMBEDDING_MODEL=

# --- GitHub (used from T1.2 onward) ---
# Fine-grained PAT scoped to the demo repo only (contents + issues + PRs).
GITHUB_TOKEN=
# Secret for HMAC verification of incoming webhooks (T3.1).
GITHUB_WEBHOOK_SECRET=
# Shared secret guarding the demo-only /simulate-event endpoint (T3.1).
SIMULATE_SHARED_SECRET=
