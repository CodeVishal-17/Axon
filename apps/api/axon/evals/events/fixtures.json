{
  "cases": [
    {
      "id": "push-default-branch",
      "event": "push",
      "delivery": "d-push-1",
      "payload": {
        "ref": "refs/heads/main",
        "after": "abc123def",
        "head_commit": {"message": "tighten token ttl"},
        "commits": [
          {"added": ["src/auth/refresh.ts"], "modified": ["src/auth/token.ts", "docs/auth.md"], "removed": []},
          {"added": [], "modified": ["src/auth/token.ts"], "removed": ["src/auth/legacy.ts"]}
        ],
        "repository": {"full_name": "acme/app"}
      },
      "expected": {
        "disposition": "event", "kind": "push",
        "changed_paths": ["docs/auth.md", "src/auth/legacy.ts", "src/auth/refresh.ts", "src/auth/token.ts"],
        "head_sha": "abc123def"
      }
    },
    {
      "id": "push-feature-branch",
      "event": "push",
      "delivery": "d-push-2",
      "payload": {
        "ref": "refs/heads/feature/x",
        "commits": [{"added": [], "modified": ["src/a.ts"], "removed": []}],
        "repository": {"full_name": "acme/app"}
      },
      "expected": {"disposition": "ignored"}
    },
    {
      "id": "pr-merged",
      "event": "pull_request",
      "delivery": "d-pr-1",
      "payload": {
        "action": "closed",
        "pull_request": {"number": 47, "merged": true, "merge_commit_sha": "fff000",
                          "title": "Reduce token TTL to 1h"},
        "repository": {"full_name": "acme/app"}
      },
      "expected": {"disposition": "event", "kind": "pr_merged", "pr_number": 47,
                    "head_sha": "fff000"}
    },
    {
      "id": "pr-opened",
      "event": "pull_request",
      "delivery": "d-pr-2",
      "payload": {
        "action": "opened",
        "pull_request": {"number": 48, "merged": false, "title": "WIP"},
        "repository": {"full_name": "acme/app"}
      },
      "expected": {"disposition": "ignored"}
    },
    {
      "id": "pr-synchronize",
      "event": "pull_request",
      "delivery": "d-pr-3",
      "payload": {
        "action": "synchronize",
        "pull_request": {"number": 48, "merged": false, "title": "WIP"},
        "repository": {"full_name": "acme/app"}
      },
      "expected": {"disposition": "ignored"}
    },
    {
      "id": "pr-closed-unmerged",
      "event": "pull_request",
      "delivery": "d-pr-4",
      "payload": {
        "action": "closed",
        "pull_request": {"number": 49, "merged": false, "title": "Abandoned"},
        "repository": {"full_name": "acme/app"}
      },
      "expected": {"disposition": "ignored"}
    },
    {
      "id": "issue-closed",
      "event": "issues",
      "delivery": "d-iss-1",
      "payload": {
        "action": "closed",
        "issue": {"number": 31, "title": "Exporter crashes on big files"},
        "repository": {"full_name": "acme/app"}
      },
      "expected": {"disposition": "event", "kind": "issue_closed", "issue_number": 31}
    },
    {
      "id": "issue-edited",
      "event": "issues",
      "delivery": "d-iss-2",
      "payload": {
        "action": "edited",
        "issue": {"number": 31, "title": "Exporter crashes on big files (repro added)"},
        "repository": {"full_name": "acme/app"}
      },
      "expected": {"disposition": "reingest", "issue_number": 31}
    },
    {
      "id": "issue-reopened",
      "event": "issues",
      "delivery": "d-iss-3",
      "payload": {
        "action": "reopened",
        "issue": {"number": 31, "title": "Exporter crashes on big files"},
        "repository": {"full_name": "acme/app"}
      },
      "expected": {"disposition": "reingest", "issue_number": 31}
    },
    {
      "id": "discussion-ignored",
      "event": "discussion",
      "delivery": "d-disc-1",
      "payload": {
        "action": "created",
        "discussion": {"number": 5, "title": "Ideas"},
        "repository": {"full_name": "acme/app"}
      },
      "expected": {"disposition": "ignored"}
    }
  ]
}
